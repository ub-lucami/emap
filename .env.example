# Copy this file to `.env` and fill the values. Do NOT commit your real `.env`.

# Django / database settings
DB_ENGINE=django.db.backends.mysql
DB_NAME=emapdb
DB_USER=emapuser
DB_PASSWORD=change_me_secure
DB_HOST=db
DB_PORT=3306

# MariaDB root password used by the image on first initialization
MYSQL_ROOT_PASSWORD=change_me_root_secure

# Django settings
SECRET_KEY=replace_with_a_secret_key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: change the port mapping in compose if needed
# WEB_PORT=8000
